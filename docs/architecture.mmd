%% Architecture Event-Driven RL Trading Pipeline
flowchart LR
    subgraph "Ingestion"
        A[Blob input/<br/>CSV OHLCV]
        EG[Event Grid]
        DISP[Function dispatcher]
    end
    subgraph "Decoupling"
        Q[Storage Queue rl-jobs]
        DLQ[Poison queue]
    end
    subgraph "RL Inference"
        W[Function worker]
        API[FastAPI Container Apps]
        AGENT[PPO Agent<br/>Stable-Baselines3]
        ENV[TradingEnv<br/>Gymnasium]
    end
    subgraph "Persistence"
        OUT[Blob output/<br/>trajectory.json]
        COS[Cosmos DB<br/>episodes]
    end
    subgraph "UI"
        SWA[Static Web App<br/>Equity curve + donut]
        HTTPF[/api/recent/]
    end
    subgraph "Observability"
        APPI[App Insights]
    end

    A --> EG --> DISP
    DISP -->|valid| Q
    DISP -->|invalid| REJ[rejected/]
    Q --> W
    Q -.->|>5 retries| DLQ
    W -->|POST /predict| API
    API --> AGENT
    AGENT --> ENV
    ENV --> AGENT
    AGENT --> API
    API --> W
    W --> OUT
    W --> COS
    SWA --> HTTPF --> COS

    DISP -.-> APPI
    W -.-> APPI
    API -.-> APPI
